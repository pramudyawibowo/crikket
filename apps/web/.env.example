NEXT_PUBLIC_SITE_URL=https://crikket.io
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true

# Custom OIDC SSO (optional)
NEXT_PUBLIC_CUSTOM_OIDC_ENABLED=false
NEXT_PUBLIC_CUSTOM_OIDC_PROVIDER_NAME=
# Posthog (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Crikket Capture (optional)
NEXT_PUBLIC_CRIKKET_KEY=

# Storage Upload Strategy (optional: auto | proxy | direct)
NEXT_PUBLIC_STORAGE_UPLOAD_MODE=auto
NEXT_PUBLIC_STORAGE_UPLOAD_CHUNK_SIZE_MB=50
